# --- Server Config ---
PORT=3001

# --- Cloudflare R2 Credentials (For Presigned URLs) ---
R2_ENDPOINT=https://<YOUR_CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here
R2_BUCKET_NAME=aeroguard-videos

# --- Redis & BullMQ (For Queueing Jobs) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Neon DB / Postgres (For Realtime SSE Dashboard) ---
PG_HOST=ep-example-host.us-east-2.aws.neon.tech
PG_DATABASE=aeroguard_db
PG_USER=your_neon_user
PG_PASSWORD=your_neon_password
PG_PORT=5432
