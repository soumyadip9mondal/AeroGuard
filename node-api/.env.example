# --- Server Config ---
PORT=3001

# --- Cloudflare R2 Credentials (For Presigned URLs) ---
CLOUDFLARE_R2_URL=s3://your_access_key_here:your_secret_key_here@your_cloudflare_account_id.r2.cloudflarestorage.com/aeroguard-videos

# --- Redis & BullMQ (For Queueing Jobs) ---
REDIS_URL=redis://default:your_redis_password@your_redis_host:6379

# --- Neon DB (Postgres) (For Realtime SSE Dashboard) ---
DATABASE_URL=postgresql://your_neon_user:your_neon_password@ep-example-host.us-east-2.aws.neon.tech/aeroguard_db?sslmode=require
