# ==============================================================================
# AeroGuard Environment Configuration Template
# ==============================================================================

# --- Node API Config ---
PORT=3001

# --- AI Service / YOLO Config ---
YOLO_MODEL=yolov8n.pt

# --- Cloudflare R2 Credentials (For Video Uploads & Storage) ---
R2_ENDPOINT=https://<YOUR_CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here
R2_BUCKET_NAME=aeroguard-videos
R2_ACCOUNT_ID=
R2_WEBHOOK_SECRET=

# --- Redis & BullMQ (For Queueing & Worker Polling) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Neon DB / Postgres ---
PG_HOST=ep-example-host.us-east-2.aws.neon.tech
PG_DATABASE=aeroguard_db
PG_USER=your_neon_user
PG_PASSWORD=your_neon_password
PG_PORT=5432
DATABASE_URL=<NeonDB connection string, dev branch>

# --- Integration and Timing Config ---
PRESIGNED_URL_EXPIRY_SECONDS=900
INFERENCE_SERVICE_URL=http://inference-service:8000
